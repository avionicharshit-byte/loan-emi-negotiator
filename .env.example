# Google AI Studio API key for Gemini
# Get one at https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: override the default model (default is gemini-2.5-flash-lite for higher free-tier limits)
# GEMINI_MODEL=gemini-2.5-flash-lite

# Optional: make demos deterministic and avoid live API calls.
# DEMO_MODE=true

# Optional: keep the app usable if Gemini quota is exhausted or the key is missing.
# Set to false if you prefer hard API errors in development.
# DEMO_FALLBACK=true
